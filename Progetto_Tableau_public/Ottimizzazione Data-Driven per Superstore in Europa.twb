      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='72526' id='7' param='horz' type-v2='layout-flow' w='98828' x='586' y='26432'>
            <zone h='72526' id='5' type-v2='layout-basic' w='85651' x='586' y='26432'>
              <zone h='72526' id='3' name='Profit_Ratio vs Discount' w='85651' x='586' y='26432'>
                <zone-style>
                  <format attr='border-color' value='#d4d4d4' />
                  <format attr='border-style' value='solid' />
                  <format attr='border-width' value='1' />
                  <format attr='margin' value='10' />
