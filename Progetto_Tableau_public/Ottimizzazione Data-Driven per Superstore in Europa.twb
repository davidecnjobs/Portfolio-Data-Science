                  <format attr='border-style' value='solid' />
                  <format attr='border-width' value='1' />
                  <format attr='margin' value='10' />
                  <format attr='padding' value='10' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
              <zone h='18359' id='11' name='Sales vs Profit Ratio' pane-specification-id='0' param='[federated.1qbrmm5043w3361a6c6ji00ty6nj].[usr:Calculation_0001070948225409:nk]' type-v2='color' w='39239' x='60175' y='70963'>
