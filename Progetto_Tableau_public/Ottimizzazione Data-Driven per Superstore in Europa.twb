      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97916' id='12' param='vert' type-v2='layout-flow' w='98828' x='586' y='1042'>
            <zone fixed-size='56' h='9896' id='13' is-fixed='true' type-v2='title' w='98828' x='586' y='1042'>
              <zone-style>
                <format attr='border-color' value='#d4d4d4' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <format attr='margin' value='10' />
                <format attr='padding' value='10' />
                <format attr='background-color' value='#ffffff' />
              </zone-style>
            </zone>
            <zone h='88020' id='8' param='horz' type-v2='layout-flow' w='98828' x='586' y='10938'>
              <zone h='88020' id='6' type-v2='layout-basic' w='98828' x='586' y='10938'>
                <zone h='88020' id='1' param='vert' type-v2='layout-flow' w='98828' x='586' y='10938'>
                  <zone fixed-size='120' forceUpdate='true' h='18229' id='3' is-fixed='true' type-v2='text' w='98828' x='586' y='10938'>
                    <formatted-text>
                      <run bold='true' fontcolor='#000000' fontsize='12'>Si nota come la rimozione di &quot;Tables&quot; abbia senso in quasi tutte le nazioni tranne in Belgio e nel Regno Unito in cui il mercato sembra essere molto diverso e a profitto positivo.</run>
                      <run>Æ&#10;</run>
                      <run bold='true' fontcolor='#000000' fontsize='12'>Raccomandazione: si consiglia di non rimuovere tutti i prodotti da &quot;Tables&quot; nel marcato Belga e in quello del Regno Unito; dato che in UK c&apos;è un singolo prodotto meno performante (come evidenziato nella tabella in basso a destra) si potrebbe procedere con la rimozione o l&apos;ottimizzazione di quest&apos;ultimo.  </run>
                    </formatted-text>
                    <zone-style>
                      <format attr='border-color' value='#d4d4d4' />
                      <format attr='border-style' value='solid' />
                      <format attr='border-width' value='1' />
                      <format attr='margin' value='10' />
                      <format attr='padding' value='10' />
                      <format attr='background-color' value='#ffffff' />
                    </zone-style>
                  </zone>
                  <zone h='69786' id='4' layout-strategy-id='distribute-evenly' param='horz' type-v2='layout-flow' w='98828' x='586' y='29167'>
                    <zone h='69791' id='5' name='Profit Retio per Nazione' w='49414' x='586' y='29167'>
                      <layout-cache cell-count-w='1' non-cell-size-w='101' type-h='cell' type-w='cell' />
