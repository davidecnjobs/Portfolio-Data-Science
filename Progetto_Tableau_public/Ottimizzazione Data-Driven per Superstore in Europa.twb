      <column caption='Azione Budget' datatype='string' name='[Calculation_0001070948225409]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0001139056337270] &gt; 0.15 AND SUM([Sales]) &gt; 170000 THEN &#10;    &quot;Investire&quot;&#10;ELSEIF [Calculation_0001139056337270] &gt; 0.15 AND SUM([Sales]) &lt; 170000 &#10;    THEN &quot;Nicchia&quot;&#10;ELSEIF [Calculation_0001139056337270] &lt; 0.15 AND SUM([Sales]) &gt; 170000&#10;    THEN &quot;Sotto-performanti&quot;&#10;ELSE &quot;Critici&quot;&#10;END' />
      </column>
      <column caption='Misura' datatype='real' name='[Calculation_0001139033915764]' role='measure' type='quantitative'>
