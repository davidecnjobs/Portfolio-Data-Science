      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='83073' id='1' param='vert' type-v2='layout-flow' w='33528' x='586' y='15885'>
            <zone fixed-size='251' forceUpdate='true' h='35286' id='10' is-fixed='true' type-v2='text' w='31918' x='1391' y='17317'>
              <formatted-text>
                <run bold='true' fontcolor='#000000' fontname='Tableau Book' fontsize='12'>La dashboard permette di scegliere mediante i selettori posti in basso la misura tra Sales e Profit e, mediante gli altri due selettori, la prima e la seconda dimensione della visualizzazione: tra Category, Sub-Category, Region e Segment.</run>
                <run>Æ&#10;</run>
                <run>Æ&#10;</run>
