              <zone fixed-size='92' h='13021' id='8' is-fixed='true' name='Fatturato vs. Redditività per Categoria' pane-specification-id='0' param='[federated.1qbrmm5043w3361a6c6ji00ty6nj].[sum:Profit:qk]' type-v2='color' w='10103' x='87774' y='21613'>
