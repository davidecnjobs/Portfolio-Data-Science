    <dashboard enable-sort-zone-taborder='true' name='Dashboard 6'>
      <repository-location derived-from='http://localhost:9100/workbooks/OttimizzazioneData-DrivenperSuperstoreinEuropa_17711536559520/Dashboard6?rev=' id='Dashboard6' path='/workbooks/OttimizzazioneData-DrivenperSuperstoreinEuropa_17711536559520' revision='' />
      <style>
        <style-rule element='table'>
          <format attr='background-color' value='#e6e6e6' />
        </style-rule>
      </style>
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' sizing-mode='fixed' />
      <datasources>
        <datasource caption='Parametri' name='Parameters' />
      </datasources>
      <datasource-dependencies datasource='Parameters'>
        <column caption='Quanti prodotti eliminare' datatype='integer' name='[Parametro 3]' param-domain-type='range' role='measure' type='quantitative' value='15'>
          <calculation class='tableau' formula='15' />
          <range max='30' min='5' />
        </column>
      </datasource-dependencies>
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97916' id='1' param='horz' type-v2='layout-flow' w='68008' x='31406' y='1042'>
            <zone h='97916' id='4' param='vert' type-v2='layout-flow' w='68008' x='31406' y='1042'>
              <zone h='97916' id='5' name='Prodotti da rimuovere' w='68008' x='31406' y='1042'>
                <layout-cache cell-count-h='15' minwidth='264' non-cell-size-h='126' type-h='cell' type-w='scalable' />
                <zone-style>
                  <format attr='border-color' value='#d4d4d4' />
                  <format attr='border-style' value='solid' />
                  <format attr='border-width' value='1' />
                  <format attr='margin' value='10' />
                  <format attr='padding' value='10' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
            </zone>
          </zone>
          <zone h='97916' id='3' param='vert' type-v2='layout-flow' w='30820' x='586' y='1042'>
            <zone custom-title='true' h='14062' id='7' mode='slider' param='[Parameters].[Parametro 3]' type-v2='paramctrl' w='30820' x='586' y='1042'>
              <formatted-text>
                <run>Quanti di prodotti da rimuovere</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#d4d4d4' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <format attr='margin' value='10' />
                <format attr='padding' value='10' />
                <format attr='background-color' value='#ffffff' />
              </zone-style>
            </zone>
            <zone fixed-size='521' forceUpdate='true' h='70443' id='8' is-fixed='true' type-v2='text' w='30820' x='586' y='15104'>
              <formatted-text>
                <run fontcolor='#000000' fontsize='10'>Basandoci sull&apos;incrocio tra Margine, Volume e Impatto degli Sconti, ecco le raccomandazioni finali:</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>1. Allocazione Budget (Investire sui prodotti di nicchia), </run>
                <run fontcolor='#000000' fontsize='10'>come </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Envelopes</run>
                <run fontcolor='#000000' fontsize='10'>, </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Paper</run>
                <run fontcolor='#000000' fontsize='10'> e </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Fasteners</run>
                <run fontcolor='#000000' fontsize='10'>.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>*</run>
                <run fontcolor='#000000' fontsize='10'>Æ </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Motivo</run>
                <run fontcolor='#000000' fontsize='10'>: hanno un Profit Ratio altissimo (vicino al 20% o superiore) ma volumi di vendita molto bassi.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>*</run>
                <run fontcolor='#000000' fontsize='10'>Æ </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Azione</run>
                <run fontcolor='#000000' fontsize='10'>: spostare budget marketing su questi segmenti per scalare le vendite senza erodere il margine.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>2. Riduzione Budget (Monitorare i prodotti sotto-performanti)</run>
                <run fontcolor='#000000' fontsize='10'>, come </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Machines</run>
                <run fontcolor='#000000' fontsize='10'> e </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Phones</run>
                <run fontcolor='#000000' fontsize='10'>.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>*</run>
                <run fontcolor='#000000' fontsize='10'>Æ </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Motivo</run>
                <run fontcolor='#000000' fontsize='10'>: generano grandi volumi di fatturato ma il profitto è cannibalizzato da sconti medi superiori al 15%.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>* Azione</run>
                <run fontcolor='#000000' fontsize='10'>: imporre un tetto massimo allo sconto (Cap) e ridurre il budget per campagne promozionali aggressive su questi prodotti.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>3. Eliminazione (Rimuovere i prodotti critici) </run>
                <run fontcolor='#000000' fontsize='10'>nella categoria </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Tables, </run>
                <run fontcolor='#000000' fontsize='10'>con focus specifico sui prodotti in perdita cronica.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>*</run>
                <run fontcolor='#000000' fontsize='10'>Æ </run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Motivo</run>
                <run fontcolor='#000000' fontsize='10'>: Tables ha il Profit Ratio più basso (-20%) nonostante lo sconto più alto (37%). Diminuire lo sconto renderebbe il prodotto invendibile; mantenerlo distrugge il capitale aziendale.</run>
                <run>Æ&#10;</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>Ecco quindi una lista di prodotti che si consiglia di rimuovere dal catalogo</run>
                <run fontcolor='#000000' fontsize='10'>, selezionando il range numerico dal selettore in alto (</run>
                <run bold='true' fontcolor='#000000' fontsize='10'>minimo 5 - massimo 30</run>
                <run fontcolor='#000000' fontsize='10'>).</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#d4d4d4' />
                <format attr='border-style' value='solid' />
                <format attr='border-width' value='1' />
                <format attr='margin' value='10' />
                <format attr='padding' value='10' />
                <format attr='background-color' value='#ffffff' />
              </zone-style>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{351FB7AB-9E62-4DDD-8673-BEB2BF8AE2F7}' />
    </dashboard>
    <dashboard enable-sort-zone-taborder='true' name='Dashboard 7'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7'>Geographic Analysis: Differentiated Strategies for the Sub-category Tables </run>
          </formatted-text>
        </title>
      </layout-options>
      <repository-location derived-from='http://localhost:9100/workbooks/OttimizzazioneData-DrivenperSuperstoreinEuropa_17711536559520/Dashboard7?rev=' id='Dashboard7' path='/workbooks/OttimizzazioneData-DrivenperSuperstoreinEuropa_17711536559520' revision='' />
      <style>
