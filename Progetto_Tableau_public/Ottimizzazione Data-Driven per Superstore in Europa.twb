      <repository-location derived-from='http://localhost:9100/workbooks/OttimizzazioneData-DrivenperSuperstoreinEuropa_17711536559520/Dashboard3?rev=' id='Dashboard3' path='/workbooks/OttimizzazioneData-DrivenperSuperstoreinEuropa_17711536559520' revision='' />
      <style>
        <style-rule element='table'>
          <format attr='background-color' value='#e6e6e6' />
        </style-rule>
      </style>
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97916' id='9' param='horz' type-v2='layout-flow' w='98828' x='586' y='1042'>
            <zone h='97916' id='3' param='vert' type-v2='layout-flow' w='59589' x='586' y='1042'>
              <zone h='7031' id='5' type-v2='title' w='59589' x='586' y='1042'>
                <zone-style>
                  <format attr='border-color' value='#d4d4d4' />
                  <format attr='border-style' value='solid' />
                  <format attr='border-width' value='1' />
                  <format attr='margin' value='10' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
              <zone h='90885' id='4' type-v2='layout-basic' w='59589' x='586' y='8073'>
                <zone h='85417' id='6' param='vert' type-v2='layout-flow' w='56515' x='2123' y='10807'>
                  <zone h='85417' id='7' name='Sales vs Profit Ratio' w='56515' x='2123' y='10807'>
                    <layout-cache minheight='206' type-h='scalable' type-w='fixed' />
                    <zone-style>
                      <format attr='border-color' value='#000000' />
                      <format attr='border-style' value='none' />
                      <format attr='border-width' value='0' />
                      <format attr='margin' value='4' />
                    </zone-style>
                  </zone>
                </zone>
                <zone-style>
                  <format attr='border-color' value='#d4d4d4' />
                  <format attr='border-style' value='solid' />
                  <format attr='border-width' value='1' />
                  <format attr='margin' value='10' />
                  <format attr='padding' value='10' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
            </zone>
            <zone fixed-size='536' h='97916' id='8' is-fixed='true' param='vert' type-v2='layout-flow' w='39239' x='60175' y='1042'>
              <zone fixed-size='376' forceUpdate='true' h='51562' id='12' is-fixed='true' type-v2='text' w='39239' x='60175' y='1042'>
                <formatted-text>
                  <run bold='true' fontcolor='#000000' fontsize='11'>Abbiamo suddiviso il grafico attraverso due linee che rappresentano la media del Profit ratio e la media delle vendite, creando così 4 quadranti che ci permettono di capire perfettamente le informazioni che vogliamo.</run>
                  <run>Æ&#10;</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontsize='11'>Analisi per Quadranti (Sales vs Profit Ratio):</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontsize='11'>* In alto a destra (Investire):</run>
                  <run fontcolor='#000000' fontsize='11'> migliori prodotti in termine di redditività e volume. Qui è efficace massimizzare l&apos;esposizione.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontsize='11'>* In alto a sinistra (Nicchia):</run>
                  <run fontcolor='#000000' fontsize='11'> prodotti molto efficienti ma con volumi bassi di vendita. Potrebbe essere funzionale potenziare le strategie di marketing per scalare le vendite.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontsize='11'>* In basso a destra (Sotto-performanti): </run>
                  <run fontcolor='#000000' fontsize='11'>grandi volumi di vendita ma con margini bassi. Il cerchio grande indica che l&apos;alto tasso di sconti sta erodendo i profitti: occorre rivedere la politica degli sconti.</run>
                  <run>Æ&#10;</run>
                  <run bold='true' fontcolor='#000000' fontsize='11'>* In basso a sinistra (Critici):</run>
                  <run fontcolor='#000000' fontsize='11'> basso volume di vendita e bassa marginalità. &quot;Tables&quot; è il caso limite: l&apos;unica categoria in perdita netta (punto rosso isolato).</run>
                </formatted-text>
                <zone-style>
                  <format attr='border-color' value='#d4d4d4' />
                  <format attr='border-style' value='solid' />
                  <format attr='border-width' value='1' />
                  <format attr='margin' value='10' />
                  <format attr='padding' value='10' />
                  <format attr='background-color' value='#ffffff' />
                </zone-style>
              </zone>
              <zone h='18359' id='10' name='Sales vs Profit Ratio' pane-specification-id='0' param='[federated.1qbrmm5043w3361a6c6ji00ty6nj].[avg:Discount:qk]' type-v2='size' w='39239' x='60175' y='52604'>
                <zone-style>
